---
const nav = [
  { href: '/', label: 'ホーム' },
  { href: '/blog', label: 'ブログ' },
  { href: '/check', label: 'DX診断' },
  { href: '/#contact', label: 'お問い合わせ' },
];
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href.replace(/#.*$/, ''));
---

<header class="site-header">
  <div class="container site-header__inner">
    <div class="brand-wrap">
      <a href="/" class="brand" aria-label="SOLEON claudecode トップへ">
        <img src="/logo.svg" alt="SOLEON" class="brand__logo" width="200" height="53" />
        <span class="brand__sub">claudecode</span>
      </a>
      <a
        href="https://soleon.jp/"
        class="brand__operator"
        target="_blank"
        rel="noopener"
      >運営：株式会社SOLEON ↗</a>
    </div>

    <nav class="nav" aria-label="メインナビゲーション">
      <button
        class="nav__toggle"
        aria-expanded="false"
        aria-controls="site-nav"
        aria-label="メニューを開閉"
      >
        <span></span><span></span><span></span>
      </button>
      <ul id="site-nav" class="nav__list">
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={['nav__link', { 'is-active': isActive(item.href) }]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--paper) 85%, transparent);
    backdrop-filter: saturate(150%) blur(12px);
    border-bottom: 1px solid var(--border-soft);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }
  .brand-wrap {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    min-width: 0;
  }
  .brand__operator {
    font-size: 0.72rem;
    color: var(--muted);
    white-space: nowrap;
    padding-left: 0.9rem;
    border-left: 1px solid var(--border);
    line-height: 1.3;
  }
  .brand__operator:hover {
    color: var(--accent-strong);
  }
  @media (max-width: 900px) {
    .brand__operator {
      display: none;
    }
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--fg);
  }
  .brand:hover {
    color: var(--fg);
  }
  /* soleon.jp と同じく幅基準でサイズ指定（ロゴ比率 約3.78:1） */
  .brand__logo {
    width: clamp(168px, 15vw, 208px);
    height: auto;
    display: block;
  }
  @media (max-width: 600px) {
    .brand__logo {
      width: 150px;
    }
  }
  .brand__sub {
    font-family: var(--font-display);
    font-size: 0.72rem;
    color: var(--accent);
    font-weight: 700;
    letter-spacing: 0.04em;
    padding: 0.1rem 0.5rem;
    border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    border-radius: 999px;
    line-height: 1.4;
  }

  .nav__list {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin: 0;
    padding: 0;
  }
  .nav__link {
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: 500;
    padding: 0.45rem 0.7rem;
    border-radius: var(--radius-sm);
  }
  .nav__link:hover,
  .nav__link.is-active {
    color: var(--fg);
  }
  .nav__link.is-active {
    background: var(--bg-elev);
  }

  .nav__toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    width: 40px;
    height: 40px;
    padding: 9px 8px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    cursor: pointer;
  }
  .nav__toggle span {
    display: block;
    height: 2px;
    background: var(--fg);
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  @media (max-width: 720px) {
    .nav__toggle {
      display: flex;
    }
    .nav__list {
      position: absolute;
      top: 72px;
      right: 0;
      left: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: var(--bg-elev);
      border-bottom: 1px solid var(--border);
      padding: 0.5rem;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.25s ease;
    }
    .nav__list.is-open {
      max-height: 60vh;
    }
    .nav__link {
      display: block;
      padding: 0.85rem 0.7rem;
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.nav__toggle');
  const list = document.getElementById('site-nav');
  toggle?.addEventListener('click', () => {
    const open = list?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(!!open));
  });
</script>
