---
/**
 * ContactForm — 静的ページから AWS サーバレスの endpoint へ fetch POST。
 * 送信先は環境変数 PUBLIC_CONTACT_ENDPOINT。未設定でもフォームは表示し、
 * 送信時に「準備中」の案内を出す（送信はブロック）。
 * スパム対策として honeypot（隠しフィールド company_url）を必ず入れる。
 */
const endpoint = import.meta.env.PUBLIC_CONTACT_ENDPOINT ?? '';
---

<div class="contact" data-endpoint={endpoint}>
  <form class="contact__form" novalidate>
    <div class="contact__row">
      <label class="contact__field">
        <span>会社名 <em>*</em></span>
        <input type="text" name="company" required autocomplete="organization" />
      </label>
      <label class="contact__field">
        <span>担当者名 <em>*</em></span>
        <input type="text" name="name" required autocomplete="name" />
      </label>
    </div>

    <div class="contact__row">
      <label class="contact__field">
        <span>メールアドレス <em>*</em></span>
        <input type="email" name="email" required autocomplete="email" />
      </label>
      <label class="contact__field">
        <span>電話番号 <em>*</em></span>
        <input
          type="tel"
          name="phone"
          required
          autocomplete="tel"
          inputmode="tel"
          placeholder="例）03-1234-5678"
        />
      </label>
    </div>

    <label class="contact__field">
      <span>お問い合わせ内容 <em>*</em></span>
      <textarea name="message" rows="5" required
        placeholder="例）生産実績のExcel集計を自動化したい／まず何ができるか相談したい など"
      ></textarea>
    </label>

    <!-- honeypot: 人間には見えない。BOTが埋めたら送信を破棄する -->
    <div class="contact__hp" aria-hidden="true">
      <label>
        この欄は入力しないでください
        <input type="text" name="company_url" tabindex="-1" autocomplete="off" />
      </label>
    </div>

    <button type="submit" class="btn btn--primary contact__submit">
      送信する
    </button>

    <p class="contact__status" role="status" aria-live="polite"></p>
  </form>

  <!-- 送信成功時に表示するサンクスパネル -->
  <div class="contact__thanks" hidden>
    <h3>お問い合わせありがとうございます</h3>
    <p class="muted">
      内容を確認のうえ、担当者より2営業日以内にご連絡いたします。<br />
      お急ぎの場合や、先に情報が欲しい場合は以下もご利用ください。
    </p>
    <div class="contact__thanks-actions">
      <a href="/check" class="btn btn--ghost">無料DX診断を試す</a>
      <a href="/blog" class="btn btn--ghost">活用事例を読む</a>
    </div>
  </div>
</div>

<style>
  .contact {
    background: var(--bg-elev);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius);
    padding: clamp(1.4rem, 4vw, 2.2rem);
  }
  .contact__form {
    display: grid;
    gap: 1.1rem;
  }
  .contact__row {
    display: grid;
    gap: 1.1rem;
  }
  @media (min-width: 560px) {
    .contact__row {
      grid-template-columns: 1fr 1fr;
    }
  }
  .contact__field {
    display: grid;
    gap: 0.4rem;
    font-size: 0.9rem;
  }
  .contact__field > span {
    color: var(--muted);
  }
  .contact__field em {
    color: var(--accent);
    font-style: normal;
  }
  .contact input,
  .contact textarea {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--fg);
    font: inherit;
    font-size: 0.95rem;
    padding: 0.7rem 0.85rem;
    resize: vertical;
  }
  .contact input:focus,
  .contact textarea:focus {
    outline: none;
    border-color: var(--accent);
  }
  /* honeypot は視覚的にもスクリーンリーダー的にも隠す */
  .contact__hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  .contact__submit {
    justify-self: start;
  }
  .contact__status {
    margin: 0;
    font-size: 0.88rem;
    min-height: 1.2em;
  }
  .contact__status.is-error {
    color: #ff8a8a;
  }
  .contact__status.is-info {
    color: var(--accent);
  }
  .contact__thanks h3 {
    margin-top: 0;
  }
  .contact__thanks-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 1.2rem;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.contact').forEach((el) => {
    const endpoint = el.dataset.endpoint ?? '';
    const form = el.querySelector<HTMLFormElement>('.contact__form')!;
    const statusEl = el.querySelector<HTMLParagraphElement>('.contact__status')!;
    const thanks = el.querySelector<HTMLElement>('.contact__thanks')!;
    const submit = el.querySelector<HTMLButtonElement>('.contact__submit')!;

    const setStatus = (msg: string, kind: '' | 'error' | 'info' = '') => {
      statusEl.textContent = msg;
      statusEl.classList.remove('is-error', 'is-info');
      if (kind) statusEl.classList.add(`is-${kind}`);
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      setStatus('');

      const fd = new FormData(form);

      // honeypot が埋まっていれば BOT とみなし、成功したふりをして破棄
      if ((fd.get('company_url') as string)?.trim()) {
        form.hidden = true;
        thanks.hidden = false;
        return;
      }

      // 必須チェック（ブラウザ標準 + フォールバック）
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      // endpoint 未設定時は送信をブロックし案内表示
      if (!endpoint) {
        setStatus(
          'ただいま送信先を準備中です。お手数ですが soleon.jp のお問い合わせ、またはメールにてご連絡ください。',
          'info'
        );
        return;
      }

      const payload = {
        company: fd.get('company'),
        name: fd.get('name'),
        email: fd.get('email'),
        phone: fd.get('phone'),
        message: fd.get('message'),
        source: 'claudecode.soleon.jp/contact',
      };

      submit.disabled = true;
      setStatus('送信中…');
      try {
        const res = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (!res.ok) throw new Error(`status ${res.status}`);
        form.hidden = true;
        thanks.hidden = false;
      } catch (err) {
        setStatus(
          '送信に失敗しました。時間をおいて再度お試しいただくか、soleon.jp よりご連絡ください。',
          'error'
        );
        submit.disabled = false;
      }
    });
  });
</script>
