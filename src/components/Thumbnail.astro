---
// src/components/Thumbnail.astro
// 記事タイトル＋カテゴリから、ブランド統一のサムネイルをSVGで自動生成する。
// クリップアート不要・全記事で一貫・自動記事にもそのまま使える。
// accent は必ずサイトのアクセント色（グローバルCSSの --accent と同じ値）に合わせること。
interface Props {
  title: string;
  category?: string;
  accent?: string;
}
// accent はサイトのアクセント色（global.css の --accent = --magenta）に一致させる
const { title, category = '', accent = '#dc0278' } = Astro.props;

// 末尾の【…】（Claude Code活用事例 など）はサムネでは省いて見やすくする
const clean = title.replace(/[【（(][^】）)]*[】）)]\s*$/g, '').trim();

// 半角は約0.55文字ぶんとして幅を見積もり、日本語の折り返しを自然にする
const unit = (ch: string) => (/[\x00-\xff]/.test(ch) ? 0.55 : 1);
function wrap(text: string, maxUnits = 16, maxLines = 4): string[] {
  const lines: string[] = [];
  let cur = '';
  let u = 0;
  for (const ch of text) {
    const w = unit(ch);
    if (u + w > maxUnits && cur) {
      lines.push(cur);
      cur = '';
      u = 0;
    }
    cur += ch;
    u += w;
  }
  if (cur) lines.push(cur);
  if (lines.length > maxLines) {
    const kept = lines.slice(0, maxLines);
    kept[maxLines - 1] = kept[maxLines - 1].replace(/.$/, '…');
    return kept;
  }
  return lines;
}
const lines = wrap(clean);
const titleSize = lines.length >= 4 ? 46 : 56;
const lineGap = lines.length >= 4 ? 60 : 76;
const startY = 316;
const pillW = category ? category.length * 30 + 48 : 0;
---
<svg
  viewBox="0 0 1200 630"
  role="img"
  aria-label={title}
  xmlns="http://www.w3.org/2000/svg"
  style="width:100%;height:auto;display:block;"
>
  <defs>
    <linearGradient id="tn-bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#0e1118" />
      <stop offset="1" stop-color="#070810" />
    </linearGradient>
    <radialGradient id="tn-glow" cx="0.82" cy="0.12" r="0.75">
      <stop offset="0" stop-color={accent} stop-opacity="0.30" />
      <stop offset="1" stop-color={accent} stop-opacity="0" />
    </radialGradient>
    <pattern id="tn-grid" width="40" height="40" patternUnits="userSpaceOnUse">
      <path d="M40 0H0V40" fill="none" stroke="#ffffff" stroke-opacity="0.045" stroke-width="1" />
    </pattern>
  </defs>

  <rect width="1200" height="630" fill="url(#tn-bg)" />
  <rect width="1200" height="630" fill="url(#tn-grid)" />
  <rect width="1200" height="630" fill="url(#tn-glow)" />

  <!-- 右上のノード装飾（エンジニアリングらしさ） -->
  <g>
    <line x1="1058" y1="118" x2="1140" y2="178" stroke={accent} stroke-opacity="0.45" stroke-width="2" />
    <circle cx="1058" cy="118" r="7" fill={accent} fill-opacity="0.9" />
    <circle cx="1140" cy="178" r="4.5" fill={accent} fill-opacity="0.55" />
  </g>

  <!-- カテゴリのピル -->
  {category && (
    <g>
      <rect x="90" y="140" width={pillW} height="48" rx="24" fill={accent} fill-opacity="0.14" stroke={accent} stroke-opacity="0.5" />
      <text x={90 + 24} y="172" font-family="'Noto Sans JP', sans-serif" font-size="26" font-weight="700" fill={accent}>{category}</text>
    </g>
  )}

  <!-- アクセントバー -->
  <rect x="92" y="238" width="48" height="6" rx="3" fill={accent} />

  <!-- タイトル -->
  <text x="90" y={startY} font-family="'Noto Sans JP', sans-serif" font-weight="800" font-size={titleSize} fill="#f3f5f8">
    {lines.map((ln, i) => (
      <tspan x="90" dy={i === 0 ? 0 : lineGap}>{ln}</tspan>
    ))}
  </text>

  <!-- フッター（ワードマーク） -->
  <text x="90" y="562" font-family="'Noto Sans JP', sans-serif" font-size="27" font-weight="800" fill="#e8eaed">SOLEON</text>
  <text x="214" y="562" font-family="'Noto Sans JP', sans-serif" font-size="22" fill="#7f8792">claudecode.soleon.jp</text>
</svg>
