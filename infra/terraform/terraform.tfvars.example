# このファイルを terraform.tfvars にコピーして値を埋める（terraform.tfvars はコミットしない）
#   cp terraform.tfvars.example terraform.tfvars

github_owner = "fs-morita"          # GitHub のユーザー名 or Org 名
github_repo  = "soleon-claudecode"  # 作成済みのリポジトリ名

